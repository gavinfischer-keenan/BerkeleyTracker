# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-token-here
INFLUXDB_ORG=berkeley

# ADS-B (dump1090)
ADSB_HOST=localhost
ADSB_SBS_PORT=30003
ADSB_JSON_PORT=30047

# AIS (AIS-catcher)
AIS_UDP_PORT=10110

# SDR serial numbers (set with rtl_eeprom -s <serial>)
SDR_ADSB_SERIAL=ADSB001
SDR_AIS_SERIAL=AIS001

# Enrichment APIs (optional — free tiers available)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
FLIGHTAWARE_API_KEY=
MARINE_TRAFFIC_API_KEY=

# Dashboard
DASHBOARD_URL=http://localhost:5050/api/ingest/tracker

# Storage
TRACKER_DB_PATH=/var/lib/berkeley/tracker.db
PHOTO_DIR=/data/photos

# Logging
LOG_LEVEL=INFO

# API
API_PORT=8083
